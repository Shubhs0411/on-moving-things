# ── Server settings ──────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Optional: server-side default API key ────────────────────────────────────
# Use this if you are hosting a shared / public instance and want to supply
# your own key so visitors don't need to enter one.
#
# Leave both blank for the default behaviour — users enter their own key in
# the browser (key is used per-request and never stored server-side).
#
# DEFAULT_PROVIDER=anthropic      # anthropic | openai | google
# DEFAULT_API_KEY=sk-ant-...
